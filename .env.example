# Copy to `.env` next to docker-compose.yml and fill in real values.
# docker-compose.yml reads these via ${VAR:-fallback}. The fallbacks are
# dev-only placeholders that also live in git history — DO NOT deploy with them.

# --- Secrets (REQUIRED for a real deploy) --------------------------------
# JWT signing key. Must be >= 32 chars. Changing it invalidates all issued tokens.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Nightscout API secret. Must match the secret configured in the nightscout service.
NIGHTSCOUT_API_SECRET=change-me

# --- Optional ------------------------------------------------------------
# Anthropic key enabling /api/meals/{id}/analyze. Leave blank to disable LLM meal analysis.
LLM_API_KEY=

# Path INSIDE the api container to the Firebase service-account JSON.
# Leave unset to disable FCM push. To enable: uncomment the api `volumes:`
# mount in docker-compose.yml and point this at the mounted path.
FIREBASE_CREDENTIALS_PATH=

# Prebuilt API image tag (CI pushes here). Defaults to glucocoach-api:latest.
API_IMAGE=glucocoach-api:latest
